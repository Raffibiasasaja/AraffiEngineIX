PORT=5000
NODE_ENV=development

# Database Configuration
# Option 1: MongoDB (uncomment to use)
# MONGODB_URI=mongodb://localhost:27017/bakso-kangen

# Option 2: SQLite (default)
DATABASE_TYPE=sqlite
SQLITE_PATH=./database/bakso-kangen.db

# JWT Configuration
JWT_SECRET=bakso-kangen-super-secret-key-2024
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100